root = true

[*]
indent_style = tab
end_of_line = lf
insert_final_newline = true
charset = utf-8

[*.xml]
indent_style = tab
indent_size = 4
continuation_indent_size = 8

[*.{sh,ps1}]
indent_style = tab
indent_size = 4

[*.{java,yml}]
indent_style = space
indent_size = 2
continuation_indent_size = 4
max_line_length = 120
